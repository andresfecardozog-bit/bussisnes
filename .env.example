# Fase 7B: template de variables de entorno.
# Copiar como `.env` en la raiz del repo para dev local.
# NUNCA commitear el `.env` real; ya esta en .gitignore.
#
# En Railway estas variables se configuran desde la UI del servicio,
# no se leen de un archivo.

# ---------- Directorios (Fase 7B) ----------
# Local: dejar sin definir -> usa ./data. Railway: montar volumen en /data.
# NUTRI_DATA_DIR=/data
# NUTRI_LOGS_DIR=/data/logs

# ---------- API bind ----------
# NUTRI_API_HOST=127.0.0.1
# NUTRI_API_PORT=8000
# Railway inyecta PORT automaticamente.

# ---------- CORS ----------
# Comma-separated. Debe incluir el dominio Vercel del frontend (Fase 7C).
# NUTRI_CORS_ORIGINS=https://nutriavicola.vercel.app,http://localhost:4200

# ---------- Entorno / seguridad ----------
# IMPORTANTE en deploy real:
# NUTRI_ENV=production
# NUTRI_ENABLE_API_DOCS=false
# ADMIN_EMAIL=admin@tu-dominio.com
# ADMIN_INITIAL_PASSWORD=<password robusta inicial>
# NUTRI_FORCE_ADMIN_RESET=false     # true solo para recuperar acceso admin
# NUTRI_AUTH_COOKIE_SECURE=true
# NUTRI_AUTH_COOKIE_SAMESITE=none
# NUTRI_AUTH_COOKIE_DOMAIN=      # opcional, vacio para host-only
# NUTRI_RATE_LIMIT_LOGIN_PER_MINUTE=20
# NUTRI_RATE_LIMIT_HEAVY_PER_10MIN=60

# Upload hardening
# NUTRI_MAX_UPLOAD_BYTES=26214400
# NUTRI_MAX_UPLOAD_FILES=50
# NUTRI_MAX_ZIP_ENTRIES=200
# NUTRI_MAX_ZIP_TOTAL_UNCOMPRESSED_BYTES=262144000
# NUTRI_MAX_ZIP_RATIO=100

# ---------- Supabase Storage (Fase 7E, opcional) ----------
# Cuando ambas esten definidas, el StorageAdapter usa SupabaseStorage.
# La SECRET KEY (antes service_role) permite writes desde el backend server-side.
# La PUBLISHABLE KEY (antes anon) NO permite writes a buckets privados.
# Rotar en Supabase -> Settings -> API si se filtran.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...
# SUPABASE_BUCKET_UPLOADS=uploads
# SUPABASE_BUCKET_OUTPUTS=outputs

# ---------- Gemini (reservado, no usado por el core) ----------
# GEMINI_API_KEY=
